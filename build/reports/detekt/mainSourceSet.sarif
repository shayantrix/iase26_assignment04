              "id": "detekt.style.UnusedPrivateProperty",
              "name": "UnusedPrivateProperty",
              "shortDescription": {
                "text": "Property is unused and should be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#unusedvariable",
              "id": "detekt.style.UnusedVariable",
              "name": "UnusedVariable",
              "shortDescription": {
                "text": "Variable is unused and should be removed."
