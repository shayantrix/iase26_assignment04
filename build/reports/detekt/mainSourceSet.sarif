            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#avoidreferentialequality",
              "id": "detekt.potential-bugs.AvoidReferentialEquality",
              "name": "AvoidReferentialEquality",
              "shortDescription": {
                "text": "Avoid using referential equality and prefer to use referential equality checks instead."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#castnullabletononnullabletype",
              "id": "detekt.potential-bugs.CastNullableToNonNullableType",
              "name": "CastNullableToNonNullableType",
              "shortDescription": {
                "text": "Nullable type to non-null type cast is found. Consider using two assertions, `null` assertions and type cast"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#casttonullabletype",
              "id": "detekt.potential-bugs.CastToNullableType",
              "name": "CastToNullableType",
              "shortDescription": {
                "text": "Use safe cast instead of unsafe cast to nullable types."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#chararraytostringcall",
              "id": "detekt.potential-bugs.CharArrayToStringCall",
              "name": "CharArrayToStringCall",
              "shortDescription": {
                "text": "`CharArray.toString()` call does not return expected result."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#deprecation",
              "id": "detekt.potential-bugs.Deprecation",
              "name": "Deprecation",
              "shortDescription": {
                "text": "Deprecated elements should not be used."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#dontdowncastcollectiontypes",
              "id": "detekt.potential-bugs.DontDowncastCollectionTypes",
              "name": "DontDowncastCollectionTypes",
              "shortDescription": {
                "text": "Down-casting immutable collection types is breaking the collection contract."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#doublemutabilityforcollection",
              "id": "detekt.potential-bugs.DoubleMutabilityForCollection",
              "name": "DoubleMutabilityForCollection",
              "shortDescription": {
                "text": "Using var with mutable collections or values leads to double mutability. Consider using val or immutable collection or value types."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#elsecaseinsteadofexhaustivewhen",
              "id": "detekt.potential-bugs.ElseCaseInsteadOfExhaustiveWhen",
              "name": "ElseCaseInsteadOfExhaustiveWhen",
              "shortDescription": {
                "text": "A `when` expression that has an exhaustive set of cases should not contain an `else` case."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#equalsalwaysreturnstrueorfalse",
              "id": "detekt.potential-bugs.EqualsAlwaysReturnsTrueOrFalse",
              "name": "EqualsAlwaysReturnsTrueOrFalse",
              "shortDescription": {
                "text": "Having an `equals()` method that always returns true or false is not a good idea. It does not follow the contract of this method. Consider a good default implementation (e.g. `this == other`)."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#equalswithhashcodeexist",
              "id": "detekt.potential-bugs.EqualsWithHashCodeExist",
              "name": "EqualsWithHashCodeExist",
              "shortDescription": {
                "text": "Always override hashCode when you override equals. All hash-based collections depend on objects meeting the equals-contract. Two equal objects must produce the same hashcode. When inheriting equals or hashcode, override the inherited and call the super method for clarification."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#exitoutsidemain",
              "id": "detekt.potential-bugs.ExitOutsideMain",
              "name": "ExitOutsideMain",
              "shortDescription": {
                "text": "Do not directly exit the process outside the `main` function. Throw an exception instead."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#explicitgarbagecollectioncall",
              "id": "detekt.potential-bugs.ExplicitGarbageCollectionCall",
              "name": "ExplicitGarbageCollectionCall",
              "shortDescription": {
                "text": "Don't try to be smarter than the JVM. Your code should work independently whether the garbage collector is disabled or not. If you face memory issues, try tuning the JVM options instead of relying on code itself."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#hasplatformtype",
              "id": "detekt.potential-bugs.HasPlatformType",
              "name": "HasPlatformType",
              "shortDescription": {
                "text": "Platform types must be declared explicitly in public APIs."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#ignoredreturnvalue",
              "id": "detekt.potential-bugs.IgnoredReturnValue",
              "name": "IgnoredReturnValue",
              "shortDescription": {
                "text": "This call returns a value which is ignored"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#implicitdefaultlocale",
              "id": "detekt.potential-bugs.ImplicitDefaultLocale",
              "name": "ImplicitDefaultLocale",
              "shortDescription": {
                "text": "Implicit default locale used for string processing. Consider using explicit locale."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#implicitunitreturntype",
              "id": "detekt.potential-bugs.ImplicitUnitReturnType",
              "name": "ImplicitUnitReturnType",
              "shortDescription": {
                "text": "Functions using expression statements have an implicit return type. Changing the type of the expression accidentally, changes the function return type. This may lead to backward incompatibility. Use a block statement to make clear this function will never return a value."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#invalidrange",
              "id": "detekt.potential-bugs.InvalidRange",
              "name": "InvalidRange",
              "shortDescription": {
                "text": "If a for loops condition is false before the first iteration, the loop will never get executed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#iteratorhasnextcallsnextmethod",
              "id": "detekt.potential-bugs.IteratorHasNextCallsNextMethod",
              "name": "IteratorHasNextCallsNextMethod",
              "shortDescription": {
                "text": "The `hasNext()` method of an Iterator implementation should not call the `next()` method. The state of the iterator should not be changed inside the `hasNext()` method. The `hasNext()` method is not supposed to have any side effects."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#iteratornotthrowingnosuchelementexception",
              "id": "detekt.potential-bugs.IteratorNotThrowingNoSuchElementException",
              "name": "IteratorNotThrowingNoSuchElementException",
              "shortDescription": {
                "text": "The `next()` method of an `Iterator` implementation should throw a `NoSuchElementException` when there are no more elements to return."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#lateinitusage",
              "id": "detekt.potential-bugs.LateinitUsage",
              "name": "LateinitUsage",
              "shortDescription": {
                "text": "Usage of `lateinit` detected. Using `lateinit` for property initialization is error prone, try using constructor injection or delegation."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#mapgetwithnotnullassertionoperator",
              "id": "detekt.potential-bugs.MapGetWithNotNullAssertionOperator",
              "name": "MapGetWithNotNullAssertionOperator",
              "shortDescription": {
                "text": "map.get() with not-null assertion operator (!!) can result in a NullPointerException. Consider usage of map.getValue(), map.getOrDefault() or map.getOrElse() instead."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#missingpackagedeclaration",
              "id": "detekt.potential-bugs.MissingPackageDeclaration",
              "name": "MissingPackageDeclaration",
              "shortDescription": {
                "text": "Kotlin source files should define a package."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#missingsupercall",
              "id": "detekt.potential-bugs.MissingSuperCall",
              "name": "MissingSuperCall",
              "shortDescription": {
                "text": "Overriding method is missing a call to overridden super method."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#missingusecall",
              "id": "detekt.potential-bugs.MissingUseCall",
              "name": "MissingUseCall",
              "shortDescription": {
                "text": "Usage of `Closeable` detected without `use` call. Using `Closeable` without `use` can be problematic as closing `Closeable` may throw exception."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#nullcheckonmutableproperty",
              "id": "detekt.potential-bugs.NullCheckOnMutableProperty",
              "name": "NullCheckOnMutableProperty",
              "shortDescription": {
                "text": "Checking nullability on a mutable property is not useful because the property may be set to null afterwards."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#nullabletostringcall",
              "id": "detekt.potential-bugs.NullableToStringCall",
              "name": "NullableToStringCall",
              "shortDescription": {
                "text": "`toString()` on nullable receiver may return the string \"null\""
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#propertyusedbeforedeclaration",
              "id": "detekt.potential-bugs.PropertyUsedBeforeDeclaration",
              "name": "PropertyUsedBeforeDeclaration",
              "shortDescription": {
                "text": "Properties before declaration should not be used."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#unconditionaljumpstatementinloop",
              "id": "detekt.potential-bugs.UnconditionalJumpStatementInLoop",
              "name": "UnconditionalJumpStatementInLoop",
              "shortDescription": {
                "text": "An unconditional jump statement in a loop is useless. The loop itself is only executed once."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#unnamedparameteruse",
              "id": "detekt.potential-bugs.UnnamedParameterUse",
              "name": "UnnamedParameterUse",
              "shortDescription": {
                "text": "Passing no named parameters can cause issue when parameters order change"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#unnecessarynotnullcheck",
              "id": "detekt.potential-bugs.UnnecessaryNotNullCheck",
              "name": "UnnecessaryNotNullCheck",
              "shortDescription": {
                "text": "Remove unnecessary not-null checks on non-null types."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#unnecessarynotnulloperator",
              "id": "detekt.potential-bugs.UnnecessaryNotNullOperator",
              "name": "UnnecessaryNotNullOperator",
              "shortDescription": {
                "text": "Unnecessary not-null unary operator (!!) detected."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#unnecessarysafecall",
              "id": "detekt.potential-bugs.UnnecessarySafeCall",
              "name": "UnnecessarySafeCall",
              "shortDescription": {
                "text": "Unnecessary safe call operator detected."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#unreachablecatchblock",
              "id": "detekt.potential-bugs.UnreachableCatchBlock",
              "name": "UnreachableCatchBlock",
              "shortDescription": {
                "text": "Unreachable catch block detected."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#unreachablecode",
              "id": "detekt.potential-bugs.UnreachableCode",
              "name": "UnreachableCode",
              "shortDescription": {
                "text": "Unreachable code detected. This code should be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#unsafecallonnullabletype",
              "id": "detekt.potential-bugs.UnsafeCallOnNullableType",
              "name": "UnsafeCallOnNullableType",
              "shortDescription": {
                "text": "Unsafe calls on nullable types detected. These calls will throw a NullPointerException in case the nullable value is null."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#unsafecast",
              "id": "detekt.potential-bugs.UnsafeCast",
              "name": "UnsafeCast",
              "shortDescription": {
                "text": "Cast operator throws an exception if the cast is not possible."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#unusedunaryoperator",
              "id": "detekt.potential-bugs.UnusedUnaryOperator",
              "name": "UnusedUnaryOperator",
              "shortDescription": {
                "text": "This unary operator is unused."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#uselesspostfixexpression",
              "id": "detekt.potential-bugs.UselessPostfixExpression",
              "name": "UselessPostfixExpression",
              "shortDescription": {
                "text": "The incremented or decremented value is unused. This value is replaced with the original value."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/potential-bugs#wrongequalstypeparameter",
              "id": "detekt.potential-bugs.WrongEqualsTypeParameter",
              "name": "WrongEqualsTypeParameter",
              "shortDescription": {
                "text": "Wrong parameter type for `equals()` method found. To correctly override the `equals()` method use `Any?`."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#errorusagewiththrowable",
              "id": "detekt.exceptions.ErrorUsageWithThrowable",
              "name": "ErrorUsageWithThrowable",
              "shortDescription": {
                "text": "Passing `Throwable` in `error` method is ambiguous. Use `error(throwable.message ?: \"No error message provided\")` instead."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#exceptionraisedinunexpectedlocation",
              "id": "detekt.exceptions.ExceptionRaisedInUnexpectedLocation",
              "name": "ExceptionRaisedInUnexpectedLocation",
              "shortDescription": {
                "text": "This method is not expected to throw exceptions. This can cause weird behavior."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#instanceofcheckforexception",
              "id": "detekt.exceptions.InstanceOfCheckForException",
              "name": "InstanceOfCheckForException",
              "shortDescription": {
                "text": "Instead of catching for a general exception type and checking for a specific exception type, use multiple catch blocks."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#notimplementeddeclaration",
              "id": "detekt.exceptions.NotImplementedDeclaration",
              "name": "NotImplementedDeclaration",
              "shortDescription": {
                "text": "The NotImplementedDeclaration should only be used when a method stub is necessary. This defers the development of the functionality of this function. Hence, the `NotImplementedDeclaration` should only serve as a temporary declaration. Before releasing, this type of declaration should be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#objectextendsthrowable",
              "id": "detekt.exceptions.ObjectExtendsThrowable",
              "name": "ObjectExtendsThrowable",
              "shortDescription": {
                "text": "An `object` should not extend any type of Throwable. Throwables are stateful and should be instantiated only when needed for when a specific error occurs. An `object`, being a singleton, that extends any type of Throwable consequently introduces a global singleton exception whose instance may be inadvertently reused from multiple places, thus introducing shared mutable state."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#printstacktrace",
              "id": "detekt.exceptions.PrintStackTrace",
              "name": "PrintStackTrace",
              "shortDescription": {
                "text": "Do not print a stack trace. These debug statements should be removed or replaced with a logger."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#rethrowcaughtexception",
              "id": "detekt.exceptions.RethrowCaughtException",
              "name": "RethrowCaughtException",
              "shortDescription": {
                "text": "Do not rethrow a caught exception of the same type."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#returnfromfinally",
              "id": "detekt.exceptions.ReturnFromFinally",
              "name": "ReturnFromFinally",
              "shortDescription": {
                "text": "Do not return within a finally statement. This can discard exceptions."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#swallowedexception",
              "id": "detekt.exceptions.SwallowedException",
              "name": "SwallowedException",
              "shortDescription": {
                "text": "The caught exception is swallowed. The original exception could be lost."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#throwingexceptionfromfinally",
              "id": "detekt.exceptions.ThrowingExceptionFromFinally",
              "name": "ThrowingExceptionFromFinally",
              "shortDescription": {
                "text": "Do not throw an exception within a finally statement. This can discard exceptions and is confusing."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#throwingexceptioninmain",
              "id": "detekt.exceptions.ThrowingExceptionInMain",
              "name": "ThrowingExceptionInMain",
              "shortDescription": {
                "text": "The main method should not throw an exception."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#throwingexceptionswithoutmessageorcause",
              "id": "detekt.exceptions.ThrowingExceptionsWithoutMessageOrCause",
              "name": "ThrowingExceptionsWithoutMessageOrCause",
              "shortDescription": {
                "text": "A call to the default constructor of an exception was detected. Instead one of the constructor overloads should be called. This allows to provide more meaningful exceptions."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#throwingnewinstanceofsameexception",
              "id": "detekt.exceptions.ThrowingNewInstanceOfSameException",
              "name": "ThrowingNewInstanceOfSameException",
              "shortDescription": {
                "text": "Avoid catch blocks that rethrow a caught exception wrapped inside a new instance of the same exception."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#toogenericexceptioncaught",
              "id": "detekt.exceptions.TooGenericExceptionCaught",
              "name": "TooGenericExceptionCaught",
              "shortDescription": {
                "text": "The caught exception is too generic. Prefer catching specific exceptions to the case that is currently handled."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/exceptions#toogenericexceptionthrown",
              "id": "detekt.exceptions.TooGenericExceptionThrown",
              "name": "TooGenericExceptionThrown",
              "shortDescription": {
                "text": "The thrown exception is too generic. Prefer throwing project specific exceptions to handle error cases."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#booleanpropertynaming",
              "id": "detekt.naming.BooleanPropertyNaming",
              "name": "BooleanPropertyNaming",
              "shortDescription": {
                "text": "Boolean property name should follow the naming convention set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#classnaming",
              "id": "detekt.naming.ClassNaming",
              "name": "ClassNaming",
              "shortDescription": {
                "text": "A class or object name should follow the naming convention set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#constructorparameternaming",
              "id": "detekt.naming.ConstructorParameterNaming",
              "name": "ConstructorParameterNaming",
              "shortDescription": {
                "text": "Constructor parameter names should follow the naming convention set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#enumnaming",
              "id": "detekt.naming.EnumNaming",
              "name": "EnumNaming",
              "shortDescription": {
                "text": "Enum names should follow the naming convention set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#forbiddenclassname",
              "id": "detekt.naming.ForbiddenClassName",
              "name": "ForbiddenClassName",
              "shortDescription": {
                "text": "Forbidden class name as per configuration detected."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#functionnamemaxlength",
              "id": "detekt.naming.FunctionNameMaxLength",
              "name": "FunctionNameMaxLength",
              "shortDescription": {
                "text": "Function names should not be longer than the maximum set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#functionnameminlength",
              "id": "detekt.naming.FunctionNameMinLength",
              "name": "FunctionNameMinLength",
              "shortDescription": {
                "text": "Function names should not be shorter than the minimum set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#functionnaming",
              "id": "detekt.naming.FunctionNaming",
              "name": "FunctionNaming",
              "shortDescription": {
                "text": "Function names should follow the naming convention set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#functionparameternaming",
              "id": "detekt.naming.FunctionParameterNaming",
              "name": "FunctionParameterNaming",
              "shortDescription": {
                "text": "Function parameter names should follow the naming convention set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#invalidpackagedeclaration",
              "id": "detekt.naming.InvalidPackageDeclaration",
              "name": "InvalidPackageDeclaration",
              "shortDescription": {
                "text": "Kotlin source files should be stored in the directory corresponding to its package statement."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#lambdaparameternaming",
              "id": "detekt.naming.LambdaParameterNaming",
              "name": "LambdaParameterNaming",
              "shortDescription": {
                "text": "Lambda parameter names should follow the naming convention set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#matchingdeclarationname",
              "id": "detekt.naming.MatchingDeclarationName",
              "name": "MatchingDeclarationName",
              "shortDescription": {
                "text": "If a source file contains only a single non-private top-level class or object, the file name should reflect the case-sensitive name plus the .kt extension."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#membernameequalsclassname",
              "id": "detekt.naming.MemberNameEqualsClassName",
              "name": "MemberNameEqualsClassName",
              "shortDescription": {
                "text": "A member should not be given the same name as its parent class or object."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#nonameshadowing",
              "id": "detekt.naming.NoNameShadowing",
              "name": "NoNameShadowing",
              "shortDescription": {
                "text": "Disallow shadowing variable declarations."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#nonbooleanpropertyprefixedwithis",
              "id": "detekt.naming.NonBooleanPropertyPrefixedWithIs",
              "name": "NonBooleanPropertyPrefixedWithIs",
              "shortDescription": {
                "text": "Only boolean property names can start with `is` prefix."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#objectpropertynaming",
              "id": "detekt.naming.ObjectPropertyNaming",
              "name": "ObjectPropertyNaming",
              "shortDescription": {
                "text": "Property names inside objects should follow the naming convention set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#packagenaming",
              "id": "detekt.naming.PackageNaming",
              "name": "PackageNaming",
              "shortDescription": {
                "text": "Package names should follow the naming convention set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#toplevelpropertynaming",
              "id": "detekt.naming.TopLevelPropertyNaming",
              "name": "TopLevelPropertyNaming",
              "shortDescription": {
                "text": "Top level property names should follow the naming convention set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#variablemaxlength",
              "id": "detekt.naming.VariableMaxLength",
              "name": "VariableMaxLength",
              "shortDescription": {
                "text": "Variable names should not be longer than the maximum set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#variableminlength",
              "id": "detekt.naming.VariableMinLength",
              "name": "VariableMinLength",
              "shortDescription": {
                "text": "Variable names should not be shorter than the minimum set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/naming#variablenaming",
              "id": "detekt.naming.VariableNaming",
              "name": "VariableNaming",
              "shortDescription": {
                "text": "Variable names should follow the naming convention set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/performance#arrayprimitive",
              "id": "detekt.performance.ArrayPrimitive",
              "name": "ArrayPrimitive",
              "shortDescription": {
                "text": "Using `Array<Primitive>` leads to implicit boxing and a performance hit."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/performance#couldbesequence",
              "id": "detekt.performance.CouldBeSequence",
              "name": "CouldBeSequence",
              "shortDescription": {
                "text": "Several chained collection operations that should be a sequence."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/performance#foreachonrange",
              "id": "detekt.performance.ForEachOnRange",
              "name": "ForEachOnRange",
              "shortDescription": {
                "text": "Using the forEach method on ranges has a heavy performance cost. Prefer using simple for loops."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/performance#spreadoperator",
              "id": "detekt.performance.SpreadOperator",
              "name": "SpreadOperator",
              "shortDescription": {
                "text": "In most cases using a spread operator causes a full copy of the array to be created before calling a method. This may result in a performance penalty."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/performance#unnecessaryinitonarray",
              "id": "detekt.performance.UnnecessaryInitOnArray",
              "name": "UnnecessaryInitOnArray",
              "shortDescription": {
                "text": "Flags array constructors that use lambda builders returning the same default value when the default initialization would produce the same result."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/performance#unnecessarypartofbinaryexpression",
              "id": "detekt.performance.UnnecessaryPartOfBinaryExpression",
              "name": "UnnecessaryPartOfBinaryExpression",
              "shortDescription": {
                "text": "Detects unnecessary checks in binary expressions."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/performance#unnecessarytemporaryinstantiation",
              "id": "detekt.performance.UnnecessaryTemporaryInstantiation",
              "name": "UnnecessaryTemporaryInstantiation",
              "shortDescription": {
                "text": "Avoid temporary objects when converting primitive types to `String`."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/performance#unnecessarytypecasting",
              "id": "detekt.performance.UnnecessaryTypeCasting",
              "name": "UnnecessaryTypeCasting",
              "shortDescription": {
                "text": "Unnecessary type casting is found. Consider using type checking."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#abstractclasscanbeconcreteclass",
              "id": "detekt.style.AbstractClassCanBeConcreteClass",
              "name": "AbstractClassCanBeConcreteClass",
              "shortDescription": {
                "text": "An abstract class is unnecessary. May be refactored to a concrete class."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#abstractclasscanbeinterface",
              "id": "detekt.style.AbstractClassCanBeInterface",
              "name": "AbstractClassCanBeInterface",
              "shortDescription": {
                "text": "An abstract class is unnecessary. May be refactored to an interface."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#alsocouldbeapply",
              "id": "detekt.style.AlsoCouldBeApply",
              "name": "AlsoCouldBeApply",
              "shortDescription": {
                "text": "When an `also` block contains only `it`-started expressions, simplify it to the `apply` block."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#bracesonifstatements",
              "id": "detekt.style.BracesOnIfStatements",
              "name": "BracesOnIfStatements",
              "shortDescription": {
                "text": "Braces do not comply with the specified policy"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#bracesonwhenstatements",
              "id": "detekt.style.BracesOnWhenStatements",
              "name": "BracesOnWhenStatements",
              "shortDescription": {
                "text": "Braces do not comply with the specified policy"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#canbenonnullable",
              "id": "detekt.style.CanBeNonNullable",
              "name": "CanBeNonNullable",
              "shortDescription": {
                "text": "Variable can be changed to non-nullable, as it is never set to null."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#cascadingcallwrapping",
              "id": "detekt.style.CascadingCallWrapping",
              "name": "CascadingCallWrapping",
              "shortDescription": {
                "text": "If a chained call is wrapped to a new line, subsequent chained calls should be as well."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#classordering",
              "id": "detekt.style.ClassOrdering",
              "name": "ClassOrdering",
              "shortDescription": {
                "text": "Class contents should be in this order: Property declarations/initializer blocks; secondary constructors; method declarations then companion objects."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#collapsibleifstatements",
              "id": "detekt.style.CollapsibleIfStatements",
              "name": "CollapsibleIfStatements",
              "shortDescription": {
                "text": "Two if statements which could be collapsed were detected. These statements can be merged to improve readability."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#dataclasscontainsfunctions",
              "id": "detekt.style.DataClassContainsFunctions",
              "name": "DataClassContainsFunctions",
              "shortDescription": {
                "text": "Data classes should mainly be used to store data and should not have any extra functions (Compiler will automatically generate equals, toString and hashCode functions)."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#dataclassshouldbeimmutable",
              "id": "detekt.style.DataClassShouldBeImmutable",
              "name": "DataClassShouldBeImmutable",
              "shortDescription": {
                "text": "Data classes should mainly be immutable and should not have any side effects (To copy an object altering some of its properties use the copy function)."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#destructuringdeclarationwithtoomanyentries",
              "id": "detekt.style.DestructuringDeclarationWithTooManyEntries",
              "name": "DestructuringDeclarationWithTooManyEntries",
              "shortDescription": {
                "text": "Too many entries in a destructuring declaration make the code hard to understand."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#doublenegativeexpression",
              "id": "detekt.style.DoubleNegativeExpression",
              "name": "DoubleNegativeExpression",
              "shortDescription": {
                "text": "Expression with two or more calls of operator `not` could be simplified."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#doublenegativelambda",
              "id": "detekt.style.DoubleNegativeLambda",
              "name": "DoubleNegativeLambda",
              "shortDescription": {
                "text": "Double negative from a function name expressed in the negative (like `takeUnless`) with a lambda block that also contains negation. This is more readable when rewritten using a positive form of the function (like `takeIf`)."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#equalsnullcall",
              "id": "detekt.style.EqualsNullCall",
              "name": "EqualsNullCall",
              "shortDescription": {
                "text": "Equals() method is called with null as parameter. Consider using == to compare to null."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#equalsonsignatureline",
              "id": "detekt.style.EqualsOnSignatureLine",
              "name": "EqualsOnSignatureLine",
              "shortDescription": {
                "text": "Equals signs for expression style functions should be on the same line as the signature."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#explicitcollectionelementaccessmethod",
              "id": "detekt.style.ExplicitCollectionElementAccessMethod",
              "name": "ExplicitCollectionElementAccessMethod",
              "shortDescription": {
                "text": "Prefer usage of the indexed access operator [] for map element access or insert methods."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#explicititlambdamultipleparameters",
              "id": "detekt.style.ExplicitItLambdaMultipleParameters",
              "name": "ExplicitItLambdaMultipleParameters",
              "shortDescription": {
                "text": "Declaring lambda parameters as `it` is inappropriate."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#explicititlambdaparameter",
              "id": "detekt.style.ExplicitItLambdaParameter",
              "name": "ExplicitItLambdaParameter",
              "shortDescription": {
                "text": "Declaring lambda parameters as `it` is redundant."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#expressionbodysyntax",
              "id": "detekt.style.ExpressionBodySyntax",
              "name": "ExpressionBodySyntax",
              "shortDescription": {
                "text": "Functions with exact one statement, the return statement, can be rewritten with ExpressionBodySyntax."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#forbiddenannotation",
              "id": "detekt.style.ForbiddenAnnotation",
              "name": "ForbiddenAnnotation",
              "shortDescription": {
                "text": "Avoid using this annotation."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#forbiddencomment",
              "id": "detekt.style.ForbiddenComment",
              "name": "ForbiddenComment",
              "shortDescription": {
                "text": "Flags a forbidden comment."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#forbiddenimport",
              "id": "detekt.style.ForbiddenImport",
              "name": "ForbiddenImport",
              "shortDescription": {
                "text": "Mark forbidden imports. A forbidden import could be an import for an unstable / experimental api and hence you might want to mark it as forbidden in order to get warned about the usage."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#forbiddenmethodcall",
              "id": "detekt.style.ForbiddenMethodCall",
              "name": "ForbiddenMethodCall",
              "shortDescription": {
                "text": "Mark forbidden methods. A forbidden method could be an invocation of an unstable / experimental method and hence you might want to mark it as forbidden in order to get warned about the usage."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#forbiddennamedparam",
              "id": "detekt.style.ForbiddenNamedParam",
              "name": "ForbiddenNamedParam",
              "shortDescription": {
                "text": "Mark the methods/constructors where using named param is forbidden."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#forbiddenoptin",
              "id": "detekt.style.ForbiddenOptIn",
              "name": "ForbiddenOptIn",
              "shortDescription": {
                "text": "Using this opt-in is forbidden."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#forbiddensuppress",
              "id": "detekt.style.ForbiddenSuppress",
              "name": "ForbiddenSuppress",
              "shortDescription": {
                "text": "Suppressing a rule which is forbidden in current configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#forbiddenvoid",
              "id": "detekt.style.ForbiddenVoid",
              "name": "ForbiddenVoid",
              "shortDescription": {
                "text": "`Unit` should be used instead of `Void`."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#functiononlyreturningconstant",
              "id": "detekt.style.FunctionOnlyReturningConstant",
              "name": "FunctionOnlyReturningConstant",
              "shortDescription": {
                "text": "A function that only returns a constant is misleading. Consider declaring a constant instead."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#loopwithtoomanyjumpstatements",
              "id": "detekt.style.LoopWithTooManyJumpStatements",
              "name": "LoopWithTooManyJumpStatements",
              "shortDescription": {
                "text": "The loop contains more than one break or continue statement. The code should be refactored to increase readability."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#magicnumber",
              "id": "detekt.style.MagicNumber",
              "name": "MagicNumber",
              "shortDescription": {
                "text": "Report magic numbers. Magic number is a numeric literal that is not defined as a constant and hence it's unclear what the purpose of this number is. It's better to declare such numbers as constants and give them a proper name. By default, -1, 0, 1, and 2 are not considered to be magic numbers."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#mandatorybracesloops",
              "id": "detekt.style.MandatoryBracesLoops",
              "name": "MandatoryBracesLoops",
              "shortDescription": {
                "text": "A multi-line loop was found that does not have braces. These should be added to improve readability."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.3/rules/style#maxchainedcallsonsameline",
              "id": "detekt.style.MaxChainedCallsOnSameLine",
              "name": "MaxChainedCallsOnSameLine",
              "shortDescription": {
